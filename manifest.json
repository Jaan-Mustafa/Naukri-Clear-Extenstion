{
  "manifest_version": 3,
  "name": "Naukri Clear — Job Clipper",
  "version": "1.0.0",
  "description": "Save job listings to your Naukri Clear tracker with one click. Works on LinkedIn, Indeed, and Naukri.",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel", "tabs"],
  "host_permissions": [
    "https://naukriclear.com/*",
    "https://api.naukriclear.com/*",
    "http://localhost:8080/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.linkedin.com/job/*",
        "https://in.linkedin.com/jobs/*",
        "https://in.linkedin.com/job/*",
        "https://www.indeed.com/*",
        "https://in.indeed.com/*",
        "https://www.naukri.com/*"
      ],
      "js": ["content/extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
